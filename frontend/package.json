{
  "name": "svelte-idas-app",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:open": "concurrently \"npm:dev:backend\" \"npm:dev:frontend -- --open\"",
    "dev:backend": "cd ../backend && dotnet watch",
    "dev:frontend": "vite",
    "build": "vite build && cd ../backend && dotnet build",
    "preview": "cd ../backend && dotnet run",
    "svelte-check": "svelte-check",
    "svelte-check:watch": "svelte-check --watch",
    "lint": "eslint .",
    "lint:prod": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@gandalan/weblibs": "^2.0.2",
    "svelte-mini-router": "^1.0.4",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/postcss": "^4.3.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "eslint-plugin-svelte": "^3.19.0",
    "postcss": "^8.5.15",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "svelte-eslint-parser": "^1.8.0",
    "tailwindcss": "^4.3.1",
    "vite": "^8.1.0"
  }
}
