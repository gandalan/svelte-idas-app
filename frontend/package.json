{
  "name": "svelte-idas-app",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:open": "concurrently \"npm:dev:backend\" \"npm:dev:frontend -- --open\"",
    "dev:backend": "cd ../backend && dotnet watch",
    "dev:frontend": "vite",
    "build": "vite build && cd ../backend && dotnet build",
    "preview": "cd ../backend && dotnet run",
    "svelte-check": "svelte-check",
    "svelte-check:watch": "svelte-check --watch",
    "lint": "eslint .",
    "lint:prod": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@gandalan/weblibs": "1.5.31",
    "svelte-mini-router": "^1.0.4",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
     "@tailwindcss/postcss": "^4.1.13",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-plugin-svelte": "^3.16.0",
    "postcss": "^8.5.8",
    "svelte": "^5.54.1",
    "svelte-check": "^4.4.5",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1"
   },
   "overrides": {
     "axios": "^1.13.6",
     "flatted": "^3.4.2"
  }
}
