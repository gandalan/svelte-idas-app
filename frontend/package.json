{
  "name": "svelte-idas-app",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:open": "concurrently \"npm:dev:backend\" \"npm:dev:frontend -- --open\"",
    "dev:backend": "cd ../backend && dotnet watch",
    "dev:frontend": "vite",
    "build": "vite build && cd ../backend && dotnet build",
    "preview": "cd ../backend && dotnet run",
    "svelte-check": "svelte-check",
    "svelte-check:watch": "svelte-check --watch",
    "lint": "eslint .",
    "lint:prod": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@gandalan/weblibs": "1.2.1",
    "svelte-mini-router": "^1.0.4",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.26.8",
    "@eslint/js": "^9.39.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-plugin-svelte": "^2.46.1",
    "postcss": "^8.5.6",
    "svelte": "^5.47.1",
    "svelte-check": "^4.3.5",
    "svelte-eslint-parser": "^1.4.1",
    "tailwindcss": "^3.4.17",
    "vite": "^7.3.1"
  }
}
